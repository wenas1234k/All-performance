if not game:IsLoaded() then game.Loaded:Wait() end

local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

-- SAFE SYSTEM
local function safe(f) pcall(f) end

local function fflag(name, value)
    safe(function()
        setfflag = setfflag or function() end
        setfflag(name, value)
    end)
end

-- =========================
-- 🌐 GITHUB LOADER
-- =========================
local GITHUB_URL = "https://raw.githubusercontent.com/wenas1234k/All-performance/main/performance-smoothV2"

local function loadGithub()
    safe(function()
        loadstring(game:HttpGet(GITHUB_URL))()
    end)
end

-- FIRST LOAD
loadGithub()

-- =========================
-- 🔁 AUTO UPDATE SYSTEM
-- =========================
task.spawn(function()
    while true do
        task.wait(60) -- cek tiap 60 detik
        loadGithub()
    end
end)

-- =========================
-- 🚀 AUTO RUN
-- =========================
task.spawn(function()
    while true do task.wait(1) end
end)

