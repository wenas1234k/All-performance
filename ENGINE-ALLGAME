    while true do
        task.wait(2)
        safe(function()
            settings().Network.IncomingReplicationLag = 0
        end)
    end
end)

-- =========================
-- 🧠 MEMORY CONTROL
-- =========================
task.spawn(function()
    while true do
        task.wait(2)
        collectgarbage("collect")
    end
end)

-- =========================
-- 🧹 CLEANER
-- =========================
task.spawn(function()
    while true do
        task.wait(5)
        for _, v in pairs(Workspace:GetDescendants()) do
            safe(function()
                if v:IsA("ParticleEmitter") or v:IsA("Trail") then v:Destroy() end
                if v:IsA("Decal") or v:IsA("Texture") then v:Destroy() end
            end)
        end
    end
end)

-- =========================
-- 🧬 AI AUTO TUNING
-- =========================
task.spawn(function()
    while true do
        task.wait(1)

        local fps = 1 / RunService.RenderStepped:Wait()

        if fps < 55 then
            -- BOOST MODE
            for _, v in pairs(Workspace:GetDescendants()) do
                safe(function()
                    if v:IsA("BasePart") then
                        v.Material = Enum.Material.SmoothPlastic
                    end
                end)
            end

        elseif fps > 80 then
            -- NORMAL MODE
            Lighting.Brightness = 1
        end
    end
end)

-- =========================
-- 💀 AUTO BRUTAL MODE (FPS DROP)
-- =========================
task.spawn(function()
    while true do
        task.wait(3)

        local fps = 1 / RunService.RenderStepped:Wait()

        if fps < 40 then
            -- BRUTAL ON
            Lighting.Brightness = 0

            for _, v in pairs(Workspace:GetDescendants()) do
                safe(function()
                    if v:IsA("BasePart") then
                        v.Transparency = 0.35
                        v.Material = Enum.Material.Plastic
                    end
                end)
            end
        end
    end
end)

