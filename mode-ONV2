--// 💀 FINAL MODULAR + GRAPH SYSTEM

if not game:IsLoaded() then
    game.Loaded:Wait()
end

-- services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")
local Stats = game:GetService("Stats")
local Terrain = workspace:FindFirstChildOfClass("Terrain")

local player = Players.LocalPlayer

--// 🛡️ SAFE
local function safe(f)
    local ok, err = pcall(f)
    if not ok then warn(err) end
end

--// 📦 MODULE SYSTEM
local Modules = {}

local function registerModule(name, func)
    Modules[name] = func
end

local function loadAllModules()
    for name, func in pairs(Modules) do
        safe(func)
    end
end

--// 📁 MULTI LOADER (Folder-based)
local function loadFromFolder(folder)
    for _, module in pairs(folder:GetChildren()) do
        if module:IsA("ModuleScript") then
            safe(function()
                require(module)()
            end)
        end
    end
end

--// 💀 PERFORMANCE MODULE
registerModule("Optimize", function()
    safe(function()
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 1e10
        Lighting.Brightness = 1
        Lighting.EnvironmentDiffuseScale = 0
        Lighting.EnvironmentSpecularScale = 0
    end)

    safe(function()
        for _, v in pairs(Lighting:GetDescendants()) do
            if v:IsA("PostEffect") then
                v:Destroy()
            end
        end
    end)

    safe(function()
        if Terrain then
            Terrain.WaterWaveSize = 0
            Terrain.WaterWaveSpeed = 0
            Terrain.WaterReflectance = 0
            Terrain.WaterTransparency = 1
        end
    end)

    safe(function()
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") then
                obj.Material = Enum.Material.SmoothPlastic
                obj.Reflectance = 0
            elseif obj:IsA("ParticleEmitter") then
                obj.Enabled = false
            end
        end
    end)

    safe(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)
end)

--// 📊 OVERLAY + GRAPH MODULE
registerModule("OverlayGraph", function()

    local gui = Instance.new("ScreenGui")
    gui.Name = "PerfGraph"
    gui.ResetOnSpawn = false

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 220, 0, 120)
    frame.Position = UDim2.new(0, 10, 0, 10)
    frame.BackgroundTransparency = 0.3
    frame.Parent = gui

    gui.Parent = player:WaitForChild("PlayerGui")

    local bars = {}
    local maxBars = 50

    for i = 1, maxBars do
        local bar = Instance.new("Frame")
        bar.Size = UDim2.new(0, 3, 0, 10)
        bar.Position = UDim2.new(0, i * 4, 1, 0)
        bar.AnchorPoint = Vector2.new(0,1)
        bar.BackgroundColor3 = Color3.new(1,1,1)
        bar.Parent = frame
        table.insert(bars, bar)
    end

    local last = tick()
    local fps = 60

    RunService.RenderStepped:Connect(function()
        local now = tick()
        fps = math.clamp(math.floor(1 / (now - last)), 0, 120)
        last = now
    end)

    task.spawn(function()
        while true do
            task.wait(0.1)

            table.remove(bars, 1)
            local newBar = Instance.new("Frame")
            newBar.Size = UDim2.new(0, 3, 0, fps)
            newBar.Position = UDim2.new(0, maxBars * 4, 1, 0)
            newBar.AnchorPoint = Vector2.new(0,1)
            newBar.BackgroundColor3 = Color3.new(1,1,1)
            newBar.Parent = frame

            table.insert(bars, newBar)
        end
    end)

end)

--// 🚀 AUTO RUN
task.spawn(function()
    loadAllModules()

    -- optional: load modules from folder
    local folder = script:FindFirstChild("Modules")
    if folder then
        loadFromFolder(folder)
    end
end)

print("🔥 FINAL GRAPH SYSTEM ACTIVE")
