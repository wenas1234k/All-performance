    local cpu = device:WaitForChild("CPU")
    cpu.Text = "Snapdragon Elite 8, 3.2 GHz"

    local gpu = device:WaitForChild("GPU")
    gpu.Text = "Adreno 740, 1.2 GHz"

    local ram = device:WaitForChild("RAM")
    ram.Text = "16 GB, 12 GB Free"

    local chipset = device:WaitForChild("Chipset")
    chipset.Text = "Snapdragon Elite 8"

    local maxPerformance = device:WaitForChild("Max Performance")
    maxPerformance.Text = "Enabled, 100% CPU"

    local fastFlags = device:WaitForChild("Fast Flags")
    fastFlags.Text = "Enabled, Fastest Flags"

    local supportAllServers = device:WaitForChild("Support All Servers")
    supportAllServers.Text = "Enabled, All Servers Supported"

    local autoRun = device:WaitForChild("Auto Run")
