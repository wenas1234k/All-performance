            _G.__ULTRA_SAFE = true
        end
    end
end)

-- 🗑️ remove old UI
protect(function()
    local old = player.PlayerGui:FindFirstChild("BrutalFPSGraph")
    if old then old:Destroy() end
end)()

-- 📊 UI GRAPH FULL
local gui = Instance.new("ScreenGui")
gui.Name = "BrutalFPSGraph"
gui.ResetOnSpawn = false

local frame = Instance.new("Frame")
frame.Size = UDim2.new(1, 0, 1, 0)
frame.BackgroundTransparency = 0.4
frame.BorderSizePixel = 0
frame.Parent = gui

gui.Parent = player:WaitForChild("PlayerGui")

-- 💀 GRAPH SYSTEM
local bars = {}
local maxBars = 140
local spacing = 9
local width = 9

for i = 1, maxBars do
    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(0, width, 0, 5)
    bar.Position = UDim2.new(0, i * spacing, 1, 0)
    bar.AnchorPoint = Vector2.new(0,1)
    bar.BorderSizePixel = 0
    bar.BackgroundColor3 = Color3.new(1,1,1)
    bar.Parent = frame
    table.insert(bars, bar)
end

-- 🔥 GRAPH LOOP (ANTI FREEZE)
task.spawn(protect(function()
    while true do
        task.wait(0.05)

        if #bars > 0 then
            bars[1]:Destroy()
            table.remove(bars, 1)
        end

        local newBar = Instance.new("Frame")

        local stepFPS = math.floor(smoothFPS / 10) * 10
        local height = math.clamp(stepFPS * 3, 10, frame.AbsoluteSize.Y)

        newBar.Size = UDim2.new(0, width, 0, height)
        newBar.Position = UDim2.new(0, maxBars * spacing, 1, 0)
        newBar.AnchorPoint = Vector2.new(0,1)
        newBar.BorderSizePixel = 0

        if stepFPS >= 60 then
            newBar.BackgroundColor3 = Color3.fromRGB(0,255,0)
        elseif stepFPS >= 30 then
            newBar.BackgroundColor3 = Color3.fromRGB(255,255,0)
        else
            newBar.BackgroundColor3 = Color3.fromRGB(255,0,0)
        end

        newBar.Parent = frame
        table.insert(bars, newBar)
    end
end))

print("💀🔥 ULTRA SAFE 120 FPS SYSTEM ACTIVE (NO CRASH)")
